# Stay tracked: .claude/, .codex/, .agents/ (skills, agent configs, project memory).
# Stay tracked: supabase/migrations/ (schema source of truth).

# ── OS cruft ──
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# ── Editor / IDE cruft ──
.idea/
*.swp
*.swo
*~

# Dependencies
node_modules/

# Next.js (build output — never commit)
.next/
out/
.turbo/

# Env — never commit DB credentials or Supabase service role (use .env.example only as template)
.env*
!.env.example

# Vercel
.vercel

# Sentry CLI auth token (never commit)
.sentryclirc

# Test / E2E artifacts (Playwright, etc. — if added later)
playwright-report/
test-results/
e2e/.auth/

# TypeScript — incremental build caches (regenerated)
*.tsbuildinfo

# ESLint / SWC caches (regenerated)
.eslintcache
.swc/

# Logs & diagnostics
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Test / coverage
coverage/

# Supabase CLI (local linked project / temp — migrations under supabase/migrations/ stay tracked)
supabase/.branches
supabase/.temp

# Local database files & dumps (SQLite, pg_dump, etc.)
*.db
*.sqlite
*.sqlite3
*.dump

# Legacy React Router artifacts (safe to remove if unused)
.react-router/
build/
