# ─────────────────────────────────────────────
# SITE IDENTITY
# Drives metadata, JSON-LD, sitemap, og: tags
# ─────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://yourdomain.com
NEXT_PUBLIC_SITE_NAME="Studio Name"
NEXT_PUBLIC_SITE_DESCRIPTION="One sentence describing the studio and what they offer."

# ─────────────────────────────────────────────
# SUPABASE
# Get from: Supabase dashboard → Settings → API
# ─────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...        # Server-only. NEVER expose to client.

# ─────────────────────────────────────────────
# SECURITY
# ─────────────────────────────────────────────
REVALIDATE_SECRET=generate-with-openssl-rand-hex-32
# On-demand cache revalidation. Set same value in Supabase webhook headers.

# ─────────────────────────────────────────────
# SENTRY (error tracking) — optional
# Opt-in: leave blank to skip Sentry init entirely (zero runtime cost).
# Set the DSN to enable client + server + edge error tracking.
# Source maps upload requires SENTRY_AUTH_TOKEN — separate concern, set
# per-environment in Vercel only when ready.
# ─────────────────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=                  # https://xxx@sentry.io/yyy
# SENTRY_TRACES_SAMPLE_RATE=0.1          # server-side tracing rate
# NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1
# NEXT_PUBLIC_SENTRY_REPLAYS_SESSION_SAMPLE_RATE=0.01
# NEXT_PUBLIC_SENTRY_REPLAYS_ON_ERROR_SAMPLE_RATE=1.0

# ─────────────────────────────────────────────
# GOHIGHLEVEL (CRM)
# Contact-form submissions upsert directly into GHL — the photographer
# reads inquiries in the GHL inbox / mobile app. Server-only credentials.
# Get from: GHL → Settings → Private Integrations → New
# ─────────────────────────────────────────────
GHL_PIT_TOKEN=pit-...                    # Private Integration Token (Bearer auth)
GHL_LOCATION_ID=                         # GHL Location ID (Settings → Business Profile)

# ─────────────────────────────────────────────
# ANALYTICS (optional — production-only)
# Layout auto-renders <GoogleTagManager /> or <GoogleAnalytics /> from
# @next/third-parties when these are set AND VERCEL_ENV === "production".
# Localhost dev + preview deploys NEVER load analytics — no test traffic
# pollution. Missing ID = no script tag (never blocks build/launch).
# Override via siteConfig.analytics if you want IDs committed to the repo
# (most clients don't — env is safer).
#
# Preferred: load GA4 INSIDE GTM, set NEXT_PUBLIC_GTM_ID only.
# GA-only setup: leave GTM blank, set NEXT_PUBLIC_GA_ID.
# Both set: GTM wins, GA tag suppressed (avoid double-counting).
# ─────────────────────────────────────────────
NEXT_PUBLIC_GTM_ID=                      # GTM-XXXXXXX (Vercel production only)
NEXT_PUBLIC_GA_ID=                       # G-XXXXXXXXXX (only if not using GTM)

# ─────────────────────────────────────────────
# SECURITY CONTACT (optional)
# Overrides siteConfig.brand.email for /.well-known/security.txt
# Use a dedicated inbox for vulnerability reports.
# ─────────────────────────────────────────────
SECURITY_CONTACT_EMAIL=                  # security@yourdomain.com
